var fibonacciIterative: (n: int) = (n: int) {
    if(n < 0) {
        console.writeln("No negative values please!")
        system.quit(1)
    }

    if(n == 0) return 0
    if (n == 1) return 1

    var a = 0
    var b = 1

    for (var i = 2; i <= n; i++) {
        const next = a + b
        a = b
        b = next
    }
    return b
}

const n = 10
console.writeln("Число Фибоначчи для n=${n}:", fibonacciIterative(n))