import { console } from "symbol"

interface Animal {
    name: string, 
    // speak: null ()
    speak: ()
}

const greet: null (Animal) = (a: Animal) {
    console.writeln(a.name)
    a.speak()
}

var dog = {
    name = "Rex", 
    speak: () = () {
        console.writeln("Woof!")
    }
}

greet(dog)
