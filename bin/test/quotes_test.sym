import { console } from "symbol"

var main = (args) {
    var name: string = "World"
    var greeting: string = "Hello, ${name}!"
    var plain: string = 'No interpolation: ${name}'
    var tab: string = 'Tab:\there'
    console.writeln(greeting)
    console.writeln(plain)
    console.writeln(tab)
}

main([])
